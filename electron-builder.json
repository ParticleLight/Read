{
  "$schema": "https://json.schemastore.org/electron-builder.json",
  "appId": "com.particle.book",
  "productName": "ParticleBook",
  "publish": {
    "provider": "github",
    "owner": "ParticleLight",
    "repo": "ParticleBook"
  },
  "compression": "maximum",
  "directories": {
    "output": "release"
  },
  "files": [
    "out/**/*",
    "!node_modules/pdfjs-dist/legacy",
    "!node_modules/pdfjs-dist/legacy/**/*",
    "!node_modules/pdfjs-dist/cmaps",
    "!node_modules/pdfjs-dist/cmaps/**/*",
    "!node_modules/pdfjs-dist/standard_fonts",
    "!node_modules/pdfjs-dist/standard_fonts/**/*",
    "!node_modules/pdfjs-dist/image_decoders",
    "!node_modules/pdfjs-dist/image_decoders/**/*",
    "!node_modules/pdfjs-dist/web",
    "!node_modules/pdfjs-dist/web/**/*",
    "!node_modules/pdfjs-dist/types",
    "!node_modules/pdfjs-dist/types/**/*",
    "!node_modules/pdfjs-dist/build/pdf.mjs.map",
    "!node_modules/pdfjs-dist/build/pdf.sandbox.mjs.map",
    "!node_modules/pdfjs-dist/build/pdf.worker.mjs.map",
    "!node_modules/pdfjs-dist/build/pdf.mjs",
    "!node_modules/pdfjs-dist/build/pdf.sandbox.mjs",
    "!node_modules/pdfjs-dist/build/pdf.sandbox.min.mjs",
    "!node_modules/pdfjs-dist/build/pdf.worker.mjs",
    "!node_modules/pdfjs-dist/webpack.mjs",
    "!node_modules/pdfjs-dist/node_modules/@napi-rs/**/*",
    "!node_modules/pdfjs-dist/node_modules",
    "!node_modules/pdfjs-dist/CODE_OF_CONDUCT.md",
    "!node_modules/pdfjs-dist/README.md",
    "!node_modules/epubjs/documentation",
    "!node_modules/epubjs/documentation/**/*",
    "!node_modules/epubjs/examples",
    "!node_modules/epubjs/examples/**/*",
    "!node_modules/epubjs/src",
    "!node_modules/epubjs/src/**/*",
    "!node_modules/epubjs/lib",
    "!node_modules/epubjs/lib/**/*",
    "!node_modules/epubjs/types",
    "!node_modules/epubjs/types/**/*",
    "!node_modules/epubjs/bower.json",
    "!node_modules/epubjs/karma.conf.js",
    "!node_modules/epubjs/webpack.config.js",
    "!node_modules/epubjs/documentation.yml",
    "!node_modules/epubjs/README.md"
  ],
  "asar": true,
  "afterPack": "./scripts/cleanup-locales.js",
  "win": {
    "target": ["nsis"],
    "icon": "resources/icon.ico",
    "signAndEditExecutable": false
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "artifactName": "${productName}-Setup-${version}.${ext}"
  },
  "mac": {
    "target": ["dmg"],
    "icon": "resources/icon.icns"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "resources/icon.png"
  }
}
